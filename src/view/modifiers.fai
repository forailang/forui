# Add a solid border around a node. `width` is in pixels and `color`
# is any CSS colour string (hex, named, rgba). For per-side borders
# we'll add `borderTop` / `borderRight` / etc. when there's a real
# need.
#
# ```fai
# Label('Card').padding(12).border(1, '#e0e6ec').cornerRadius(8)
# ```
def border
    @param node ViewNode
    @param width Int
    @param color String
    @return ViewNode
do
    var props = set(node.props, 'borderWidth', width)
    props = set(props, 'borderColor', color)
    let result = ViewNode(kind: node.kind, key: node.key, props: props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

# Add a solid border on the left side only.
def borderLeft
    @param node ViewNode
    @param width Int
    @param color String
    @return ViewNode
do
    var props = set(node.props, 'borderLeftWidth', width)
    props = set(props, 'borderLeftColor', color)
    let result = ViewNode(kind: node.kind, key: node.key, props: props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

