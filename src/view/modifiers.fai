test margin
    it 'one-arg form sets a single margin prop'
        let n = Label('x')
            .margin(12)
        assert.equals(getIntProp(n, 'margin'), 12)
    end
    it 'two-arg form sets vertical and horizontal sides'
        let n = Label('x')
            .margin(4, 8)
        assert.equals(getIntProp(n, 'marginTop'), 4)
        assert.equals(getIntProp(n, 'marginBottom'), 4)
        assert.equals(getIntProp(n, 'marginLeft'), 8)
        assert.equals(getIntProp(n, 'marginRight'), 8)
        assert.equals(hasProp(n, 'margin'), false)
    end
    it 'four-arg form sets each side individually in t/r/b/l order'
        let n = Label('x')
            .margin(1, 2, 3, 4)
        assert.equals(getIntProp(n, 'marginTop'), 1)
        assert.equals(getIntProp(n, 'marginRight'), 2)
        assert.equals(getIntProp(n, 'marginBottom'), 3)
        assert.equals(getIntProp(n, 'marginLeft'), 4)
    end
end

