use std.array

# ── Modifiers (UFCS-friendly) ───────────────────────────────────────
# Add inner padding around a node's content. Pixels.
#
# - `padding(n)` — all four sides equal to `n`.
# - `padding(v, h)` — vertical (top/bottom) and horizontal (left/right).
# - `padding(t, r, b, l)` — explicit CSS shorthand order.
#
# Unset positional args default to `-1`; any side that comes through as
# `-1` is treated as "not provided" and falls back to the shorter form.
#
# ```fai
# VStack do
#     Label('content')
# end.padding(16)
# Label('cell').padding(4, 8)
# Label('cell').padding(4, 8, 4, 8)
# ```
def padding
    @param node ViewNode
    @param top Int
    @param right Int, default: -1
    @param bottom Int, default: -1
    @param left Int, default: -1
    @return ViewNode
do
    var props = node.props
    if right < 0
        props = set(props, 'padding', top)
    else if bottom < 0
        props = set(props, 'paddingTop', top)
        props = set(props, 'paddingBottom', top)
        props = set(props, 'paddingLeft', right)
        props = set(props, 'paddingRight', right)
    else
        props = set(props, 'paddingTop', top)
        props = set(props, 'paddingRight', right)
        props = set(props, 'paddingBottom', bottom)
        props = set(props, 'paddingLeft', left)
    end
    let result = ViewNode(kind: node.kind, key: node.key, props: props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

# Set top-side padding only (pixels). Other sides are unaffected.
#
# ```fai
# Label('row').paddingTop(8)
# ```
def paddingTop
    @param node ViewNode
    @param amount Int
    @return ViewNode
do
    let props = set(node.props, 'paddingTop', amount)
    let result = ViewNode(kind: node.kind, key: node.key, props: props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

