# Set a stable key for list reconciliation. Apply this to each node
# produced inside a `for` loop so the diff can track identity across
# renders — otherwise items may flicker or lose focus when the list
# reorders.
# Do not use `withKey` as a styling hook. HTML renderers may expose the
# key as `data-fai-key` for patching/debugging, but CSS should use
# first-class modifiers or `cssClass` instead.
#
# ```fai
# for task in tasks
#     TaskCard(task).withKey(convert.toString(task.id))
# end
# ```
def withKey
    @param node ViewNode
    @param value String
    @return ViewNode
do
    let result = ViewNode(kind: node.kind, key: value, props: node.props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

# Attach a CSS class to a node in addition to its framework class.
# The HTML renderer always emits the kind-specific `fai-*` class
# (e.g. `fai-span` for `Span`); `cssClass` appends the user-supplied
# name so app stylesheets can hook nodes without inline `style="…"`
# repetition.
#
# The main use case is syntax-highlighted token streams — pair each
# `Span` with one of a small palette of class names that app CSS
# styles:
#
# ```fai
# Pre do
#     Span('def').cssClass('tok-kw')
#     Span(' add')
#     Span('\n# Add two numbers.').cssClass('tok-cmt')
# end
# ```
#
# It also works on any other node kind — `Label('beta').cssClass('badge')`
# is fine — but treat it as an escape hatch for reusable app CSS,
# pseudo-selectors, media queries, syntax highlighting, or missing Forui
# modifiers. Prefer first-class modifiers for ordinary layout,
# typography, spacing, and colors.
def cssClass
    @param node ViewNode
    @param name String
    @return ViewNode
do
    let props = set(node.props, 'cssClass', name)
    let result = ViewNode(kind: node.kind, key: node.key, props: props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

test padding
    it 'adds padding to a node'
        let l = Label('hello')
            .padding(10)
        assert.equals(l.kind, 'Label')
        assert.equals(getIntProp(l, 'padding'), 10)
    end
    it 'two-arg form sets vertical and horizontal sides'
        let l = Label('hello')
            .padding(4, 8)
        assert.equals(getIntProp(l, 'paddingTop'), 4)
        assert.equals(getIntProp(l, 'paddingBottom'), 4)
        assert.equals(getIntProp(l, 'paddingLeft'), 8)
        assert.equals(getIntProp(l, 'paddingRight'), 8)
        assert.equals(hasProp(l, 'padding'), false)
    end
    it 'four-arg form sets each side individually in t/r/b/l order'
        let l = Label('hello')
            .padding(1, 2, 3, 4)
        assert.equals(getIntProp(l, 'paddingTop'), 1)
        assert.equals(getIntProp(l, 'paddingRight'), 2)
        assert.equals(getIntProp(l, 'paddingBottom'), 3)
        assert.equals(getIntProp(l, 'paddingLeft'), 4)
        assert.equals(hasProp(l, 'padding'), false)
    end
    it 'chains multiple modifiers'
        let l = Label('hello')
            .padding(10)
            .background('blue')
            .foreground('white')
        assert.equals(getIntProp(l, 'padding'), 10)
        assert.equals(getProp(l, 'background'), 'blue')
        assert.equals(getProp(l, 'foreground'), 'white')
    end
    it 'builds a complete UI tree'
        let tree = VStack do
            Label('Title')
                .fontSize(24)
            HStack do
                Button('Save')
                    .onClick do
                        print('save')
                    end
                Button('Cancel')
            end
            Spacer()
        end
        assert.equals(tree.kind, 'VStack')
        assert.equals(childCount(tree), 3)
        assert.equals(getChild(tree, 1).kind, 'HStack')
        assert.equals(childCount(getChild(tree, 1)), 2)
        assert.equals(getChild(tree, 2).kind, 'Spacer')
    end
end

