# Add outer margin around a node. Pixels. Mirrors `padding`.
#
# - `margin(n)` — all four sides equal to `n`.
# - `margin(v, h)` — vertical (top/bottom) and horizontal (left/right).
# - `margin(t, r, b, l)` — explicit CSS shorthand order.
#
# ```fai
# Label('hero').margin(24)
# Label('cell').margin(4, 8)
# Label('cell').margin(4, 8, 4, 8)
# ```
def margin
    @param node ViewNode
    @param top Int
    @param right Int, default: -1
    @param bottom Int, default: -1
    @param left Int, default: -1
    @return ViewNode
do
    var props = node.props
    if right < 0
        props = set(props, 'margin', top)
    else if bottom < 0
        props = set(props, 'marginTop', top)
        props = set(props, 'marginBottom', top)
        props = set(props, 'marginLeft', right)
        props = set(props, 'marginRight', right)
    else
        props = set(props, 'marginTop', top)
        props = set(props, 'marginRight', right)
        props = set(props, 'marginBottom', bottom)
        props = set(props, 'marginLeft', left)
    end
    let result = ViewNode(kind: node.kind, key: node.key, props: props, children: node.children, events: node.events)
    replaceLastNode(result)
    result
end

