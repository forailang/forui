test withKey
    it 'sets a stable identity key on the node'
        let n = Label('x')
            .withKey('row-7')
        assert.equals(n.key, 'row-7')
    end
end

test cssClass
    it 'sets the cssClass prop'
        let n = Span('def')
            .cssClass('tok-kw')
        assert.equals(getProp(n, 'cssClass'), 'tok-kw')
    end
    it 'preserves the node kind and key'
        let n = Span('def')
            .withKey('first-kw')
            .cssClass('tok-kw')
        assert.equals(n.kind, 'Span')
        assert.equals(n.key, 'first-kw')
        assert.equals(getProp(n, 'cssClass'), 'tok-kw')
    end
end

